# ─────────────────────────────────────────────────────────
# Pure Deshi — Environment Variables Template
# ─────────────────────────────────────────────────────────
# 1. Copy this file and rename the copy to ".env.local"
# 2. Fill in the real values below (from MongoDB Atlas / Cloudinary)
# 3. Never commit ".env.local" to GitHub — it's already in .gitignore
# ─────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get this from: Atlas dashboard -> Database -> Connect -> Drivers
# Looks like: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/puredeshi?retryWrites=true&w=majority
MONGODB_URI=

# Cloudinary credentials
# Get these from: Cloudinary dashboard homepage (shown right after login)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Site name (used in page titles / metadata)
NEXT_PUBLIC_SITE_NAME=Pure Deshi

# A long random string used to sign admin login sessions.
# Generate one by running this in your terminal:  openssl rand -base64 32
# (any random 32+ character string works fine — it just needs to be secret)
AUTH_SECRET=

# Used ONLY by the one-time seed script (npm run seed) to create your admin
# login. Pick your own username/password — this is what you'll log into the
# admin panel with later. Safe to change and re-run "npm run seed" to reset
# the password if you forget it.
ADMIN_USERNAME=
ADMIN_PASSWORD=
